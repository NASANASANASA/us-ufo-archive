{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://uap-archives.org",
          "https://www.uap-archives.org",
          "http://localhost:9001",
          "http://127.0.0.1:9001"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "Content-Length",
        "Content-Type",
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
